# BrightKids configuration example.
# Copy to config.yaml (gitignored) and edit. Precedence: flags > env > YAML.
# Every key can be overridden by an env var prefixed BRIGHTKIDS_, e.g.
#   BRIGHTKIDS_SERVER_PORT=9000  BRIGHTKIDS_LOG_LEVEL=debug

# Storage mode for child profiles, progress, and settings:
#   private (default) — self-hosted; persisted server-side in SQLite (db.path).
#   public            — stored only in the browser's localStorage; the server
#                       is stateless and opens no database (db.path is ignored).
# Override with BRIGHTKIDS_MODE=public  or  --mode public.
mode: "private"

server:
  host: "0.0.0.0"
  port: 8080

db:
  # Path to the SQLite database. Use ":memory:" for an ephemeral store.
  path: "./brightkids.db"

log:
  level: "info"    # debug | info | warn | error
  format: "json"   # json (prod) | text (dev)

content:
  # Leave empty to use the content embedded in the binary.
  # Set to a directory to hot-iterate lesson YAML without rebuilding.
  dir: ""

metrics:
  enabled: true

analytics:
  # Google Analytics measurement ID (e.g. "G-XXXXXXXXXX"). Leave empty to
  # disable. When set, the gtag.js snippet is injected into served pages.
  # Override with BRIGHTKIDS_ANALYTICS_GA_ID or --ga-id.
  ga_id: ""

tts:
  # Text-to-speech narration. Off by default: no Listen button and no narration
  # on any screen. Set true to enable (he-IL for Hebrew/Math, en-US for English).
  # Override with BRIGHTKIDS_TTS_ENABLED=true or --tts.
  enabled: false
